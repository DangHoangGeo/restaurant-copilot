NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PASSWORD=your_database_password

# One-time operational bootstrap for the first platform admin.
# Do not expose these through public app flows.
PLATFORM_BOOTSTRAP_ADMIN_EMAIL=ops@example.com
PLATFORM_BOOTSTRAP_ADMIN_FULL_NAME=Platform Operator
PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=
PLATFORM_BOOTSTRAP_GENERATE_PASSWORD=false
PLATFORM_BOOTSTRAP_CONFIRM=create-platform-admin

# Feature Flags
# Enable/disable features globally. These control what is shown in the dashboard.
NEXT_PUBLIC_FEATURE_PAYMENTS=false
# Enable AI-powered features (menu descriptions, customer chat, etc.)
NEXT_PUBLIC_FEATURE_AI=true
# Enable online review management system
NEXT_PUBLIC_FEATURE_REVIEWS=true
# Enable low stock alerts for inventory
NEXT_PUBLIC_FEATURE_LOWSTOCK=true
# Enable table booking and pre-ordering
NEXT_PUBLIC_FEATURE_TABLEBOOKING=true
# Enable onboarding flow for new restaurants
NEXT_PUBLIC_FEATURE_ONBOARDING=true

# Security & Third-party Services
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
NEXT_PRIVATE_CAPTCHA_SECRET=
NEXT_PRIVATE_STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PRIVATE_OPENAI_API_KEY=

# Google Gemini AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Gemini Model Configuration (defaults to gemini-pro)
# GEMINI_MODEL=gemini-1.5-pro
# GEMINI_TEXT_MODEL_FAST=gemini-3.1-flash-preview
NEXT_PUBLIC_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Performance & Caching Configuration
# Cache durations in seconds
CACHE_MENU_DURATION=300
CACHE_RESTAURANT_DURATION=3600
CACHE_USER_DURATION=1800

# Logging Configuration
NEXT_PUBLIC_ENABLE_CLIENT_LOGGING=false
LOG_LEVEL=INFO

# Email Notifications (Resend - https://resend.com)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
NOTIFY_LOW_STOCK=false

# Error Monitoring (Sentry - https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/your_project_id
